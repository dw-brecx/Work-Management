# Copy this to .env and fill in your values

# From resend.com → API Keys
RESEND_API_KEY=re_your_key_here

# The "from" address — must be a verified domain on Resend
# During testing you can use: onboarding@resend.dev (only delivers to your own email)
FROM_EMAIL=WorkNest <noreply@yourdomain.com>

# Your deployed URL (used in invite links)
APP_URL=https://your-app.onrender.com

# A long random string for signing sessions — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Absolute path to the SQLite database file
# On Render: set to /data/worknest.db after mounting a persistent disk at /data
DB_PATH=/data/worknest.db

# Absolute path to the uploads directory
# On Render: set to /data/uploads after mounting a persistent disk at /data
UPLOADS_DIR=/data/uploads
