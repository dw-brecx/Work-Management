# Copy this file to ".env" and fill in your key, OR just set the variable in
# your shell before running. The Claude key is OPTIONAL — without it the agent
# still gathers reviews, it just skips the AI clean-up/variant-tagging pass.

# Your Anthropic API key (https://console.anthropic.com/). Optional.
ANTHROPIC_API_KEY=

# Which Claude model does the clean-up pass. Defaults to a fast, cheap model.
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Port the local control panel runs on.
PORT=4577
